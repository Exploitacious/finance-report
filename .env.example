# API Keys
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FRED_API_KEY=your_fred_key
SCHWAB_API_KEY=your_schwab_app_key
SCHWAB_API_SECRET=your_schwab_app_secret

# Configuration
# Path to the schwab tokens file. If running in docker, this should likely remain as is
# and the file should be mounted to /app/data/tokens.json
SCHWAB_TOKEN_FILE=/app/data/tokens.json

# Directory to store persistent data (report.md, news state, tokens)
DATA_DIR=/app/data
